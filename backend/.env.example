NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/arebianveda

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRE=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (initial seed)
ADMIN_EMAIL=admin@arebianveda.com
ADMIN_PASSWORD=Admin@123

# Email — Brevo Transactional API (HTTP, not SMTP)
BREVO_API_KEY=your_brevo_api_key
FROM_EMAIL=noreply@arebianveda.com
FROM_NAME=Arebianveda
CONTACT_EMAIL=support@arebianveda.com

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
